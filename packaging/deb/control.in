Source: globalprotect-openconnect
Section: net
Priority: optional
Maintainer: Kevin Yue <k3vinyue@gmail.com>
Standards-Version: 4.1.4
Build-Depends: debhelper (>= 9),
  autoconf,
  automake,
  autopoint,
  libtool,
  patch,
  pkg-config,
  make (>= 4),
  libssl-dev,
  libxml2-dev,
  zlib1g-dev,
  liblz4-dev,
  libgnutls28-dev,
  libp11-kit-dev,
  nettle-dev,
  libgmp-dev,
  libsecret-1-0,
  libayatana-appindicator3-1,
  gnome-keyring,
  libwebkit2gtk-4.1-dev,
  rust-@RUST_VERSION@-all
Homepage: https://github.com/yuezk/GlobalProtect-openconnect

Package: globalprotect-openconnect
Architecture: any
Multi-Arch: foreign
Depends:
  ${misc:Depends},
  ${shlibs:Depends},
  libsecret-1-0,
  libayatana-appindicator3-1,
  gnome-keyring,
Description: A GUI client for GlobalProtect VPN
 A GUI client for GlobalProtect VPN, based on OpenConnect, supports the SSO authentication method.
