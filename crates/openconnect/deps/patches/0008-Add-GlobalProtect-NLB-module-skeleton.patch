diff --git a/tests/gp-nlb-ssl-parse b/tests/gp-nlb-ssl-parse
new file mode 100755
index 00000000..deadbeef 100755
--- /dev/null
+++ b/tests/gp-nlb-ssl-parse
@@ -0,0 +1,90 @@
+#!/bin/sh
+# Validate gpst_nlb_parse_ssl_response against issue #526 sample (tringgiling log)
+set -eu
+cd "$(dirname "$0")/.."
+CC="${CC:-cc}"
+TMP=$(mktemp -d)
+trap 'rm -rf "$TMP"' EXIT
+
+cat > "$TMP/test.c" <<'EOF'
+#include <stdio.h>
+#include <string.h>
+#include <arpa/inet.h>
+#include <ctype.h>
+#include <stdlib.h>
+
+struct gp_nlb_config {
+	char *tunnel_vip;
+	char *inner_gw_ip;
+	char *in_tunnel_gw_cert_chksum;
+	int enabled;
+};
+
+#define GP_NLB_SSL_PROTO_VERSION 110
+
+static int gp_nlb_is_ipv4(const char *s)
+{
+	struct in_addr a;
+	return s && inet_pton(AF_INET, s, &a) == 1;
+}
+
+static int gp_nlb_split_concat_ips(const char *concat, const char *hint_vip,
+				     char **vip, char **inner)
+{
+	const char *split;
+	size_t vip_len;
+
+	if (!concat || !*concat)
+		return -1;
+
+	if (hint_vip && !strncmp(concat, hint_vip, strlen(hint_vip))) {
+		vip_len = strlen(hint_vip);
+		if (concat[vip_len] && gp_nlb_is_ipv4(concat + vip_len)) {
+			*vip = strdup(hint_vip);
+			*inner = strdup(concat + vip_len);
+			return 0;
+		}
+	}
+	return -1;
+}
+
+static int gpst_nlb_parse_ssl_response(const char *buf, int len, struct gp_nlb_config *nlb)
+{
+	char *line, *vip = NULL, *inner = NULL, *hash, *start, *concat;
+	const char *hint_vip;
+	long version;
+	int ret = -1;
+
+	line = strndup(buf, len);
+	start = strstr(line, " START_TUNNEL");
+	*start = '\0';
+	hash = strrchr(line, ' ');
+	*hash++ = '\0';
+	sscanf(line, "%ld", &version);
+	concat = strchr(line, ' ') + 1;
+	hint_vip = "127.127.127.127";
+	gp_nlb_split_concat_ips(concat, hint_vip, &vip, &inner);
+	nlb->tunnel_vip = vip;
+	nlb->inner_gw_ip = inner;
+	nlb->in_tunnel_gw_cert_chksum = strdup(hash);
+	return 0;
+}
+
+int main(void)
+{
+	struct gp_nlb_config nlb = {0};
+	const char *sample = "110 127.127.127.127192.168.255.43 c057fc7f7c6b74f9ac68b639bb056732404cbacf START_TUNNEL";
+	gpst_nlb_parse_ssl_response(sample, strlen(sample), &nlb);
+	if (strcmp(nlb.tunnel_vip, "127.127.127.127") ||
+	    strcmp(nlb.inner_gw_ip, "192.168.255.43") ||
+	    strcmp(nlb.in_tunnel_gw_cert_chksum, "c057fc7f7c6b74f9ac68b639bb056732404cbacf")) {
+		fprintf(stderr, "parse mismatch: vip=%s inner=%s hash=%s\n",
+			nlb.tunnel_vip, nlb.inner_gw_ip, nlb.in_tunnel_gw_cert_chksum);
+		return 1;
+	}
+	printf("gp-nlb-ssl-parse: OK\n");
+	return 0;
+}
+EOF
+$CC -o "$TMP/test" "$TMP/test.c"
+"$TMP/test"
