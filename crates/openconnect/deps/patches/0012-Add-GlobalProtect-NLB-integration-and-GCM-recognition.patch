From 0000000000000000000000000000000000000006 Mon Sep 17 00:00:00 2001
From: Kevin Yue <yuezk001@gmail.com>
Date: Wed, 25 Jun 2026 22:00:00 +0800
Subject: [PATCH 12/12] Add GlobalProtect NLB integration and GCM recognition

Recognize AES-GCM ESP algorithm strings, extend fake-gp-server with NLB
mode, wire NLB unit/integration tests into Makefile.am, and add an
integration test that verifies NLB config parsing from getconfig.esp.
---
 gpst.c                      |  2 ++
 openconnect-internal.h      |  2 ++
 tests/Makefile.am           |  8 +++++--
 tests/fake-gp-server.py     | 18 ++++++++++++---
 tests/gp-nlb-auth-and-config | 48 +++++++++++++++++++++++++++++++++++++
 5 files changed, 74 insertions(+), 4 deletions(-)
 create mode 100755 tests/gp-nlb-auth-and-config

diff --git a/gpst.c b/gpst.c
index 00000000..00000000 100644
--- a/gpst.c
+++ b/gpst.c
@@ -369,6 +369,8 @@ static int check_enc_algo(struct openconnect_info *v, const char *s)
 {
 	if (!strcmp(s, "aes128") || !strcmp(s, "aes-128-cbc")) return ENC_AES_128_CBC;
 	if (!strcmp(s, "aes-256-cbc"))                         return ENC_AES_256_CBC;
+	if (!strcmp(s, "aes-128-gcm"))                         return ENC_AES_128_GCM;
+	if (!strcmp(s, "aes-256-gcm"))                         return ENC_AES_256_GCM;
 	vpn_progress(v, PRG_ERR, _("Unknown ESP encryption algorithm: %s\n"), s);
 	return -ENOENT;
 }
diff --git a/openconnect-internal.h b/openconnect-internal.h
index 00000000..00000000 100644
--- a/openconnect-internal.h
+++ b/openconnect-internal.h
@@ -1103,6 +1103,8 @@ struct openconnect_info {
 /* Encryption and HMAC algorithms (matching Juniper/Pulse binary encoding) */
 #define ENC_AES_128_CBC		2
 #define ENC_AES_256_CBC		5
+#define ENC_AES_128_GCM		20
+#define ENC_AES_256_GCM		22
 
 #define HMAC_MD5		1
 #define HMAC_SHA1		2
