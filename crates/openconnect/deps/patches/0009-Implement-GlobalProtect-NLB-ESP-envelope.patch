@@ -0,0 +1,107 @@
+#!/bin/sh
+# Validate NLB ESP envelope header encode/decode roundtrip
+set -eu
+cd "$(dirname "$0")/.."
+CC="${CC:-cc}"
+TMP=$(mktemp -d)
+trap 'rm -rf "$TMP"' EXIT
+
+cat > "$TMP/test.c" <<'EOF'
+#include <stdio.h>
+#include <stdint.h>
+#include <string.h>
+#include <arpa/inet.h>
+
+#define GP_NLB_HDR_LEN 16
+#define GP_NLB_MAGIC 0x1a2b3c4d
+#define GP_NLB_TYPE_KEEPALIVE 0
+#define GP_NLB_TYPE_DATA 1
+
+static inline void store_be32(void *p, uint32_t d)
+{
+	uint32_t n = htonl(d);
+	memcpy(p, &n, 4);
+}
+
+static inline void store_be16(void *p, uint16_t d)
+{
+	uint16_t n = htons(d);
+	memcpy(p, &n, 2);
+}
+
+static inline uint32_t load_be32(const void *p)
+{
+	uint32_t n;
+	memcpy(&n, p, 4);
+	return ntohl(n);
+}
+
+static inline uint16_t load_be16(const void *p)
+{
+	uint16_t n;
+	memcpy(&n, p, 2);
+	return ntohs(n);
+}
+
+static void gp_nlb_write_hdr(unsigned char *hdr, uint16_t inner_len, uint8_t type)
+{
+	store_be32(hdr, GP_NLB_MAGIC);
+	store_be16(hdr + 4, 0);
+	store_be16(hdr + 6, inner_len);
+	hdr[8] = type;
+	hdr[9] = 0;
+	memset(hdr + 10, 0, 6);
+}
+
+static int gp_nlb_decap(unsigned char *wire, int *len)
+{
+	int wire_len = *len;
+	uint16_t inner_len;
+	uint8_t type;
+
+	if (wire_len < GP_NLB_HDR_LEN)
+		return -1;
+	if (load_be32(wire) != GP_NLB_MAGIC)
+		return -1;
+	type = wire[8];
+	inner_len = load_be16(wire + 6);
+	if (wire_len != GP_NLB_HDR_LEN + inner_len)
+		return -1;
+	if (type == GP_NLB_TYPE_KEEPALIVE)
+		return 1;
+	memmove(wire, wire + GP_NLB_HDR_LEN, inner_len);
+	*len = inner_len;
+	return 0;
+}
+
+int main(void)
+{
+	unsigned char buf[128];
+	unsigned char esp[] = { 0xde, 0xad, 0xbe, 0xef, 0x01, 0x02, 0x03, 0x04 };
+	int len, ret;
+
+	/* keepalive: header only */
+	gp_nlb_write_hdr(buf, 0, GP_NLB_TYPE_KEEPALIVE);
+	len = GP_NLB_HDR_LEN;
+	ret = gp_nlb_decap(buf, &len);
+	if (ret != 1 || len != GP_NLB_HDR_LEN) {
+		fprintf(stderr, "keepalive decap failed ret=%d len=%d\n", ret, len);
+		return 1;
+	}
+
+	/* data: header + fake ESP payload */
+	memcpy(buf + GP_NLB_HDR_LEN, esp, sizeof(esp));
+	gp_nlb_write_hdr(buf, sizeof(esp), GP_NLB_TYPE_DATA);
+	len = GP_NLB_HDR_LEN + sizeof(esp);
+	ret = gp_nlb_decap(buf, &len);
+	if (ret != 0 || len != (int)sizeof(esp) || memcmp(buf, esp, sizeof(esp))) {
+		fprintf(stderr, "data decap failed ret=%d len=%d\n", ret, len);
+		return 1;
+	}
+
+	printf("gp-nlb-esp-envelope: OK\n");
+	return 0;
+}
+EOF
+$CC -o "$TMP/test" "$TMP/test.c"
+"$TMP/test"
\ No newline at end of file
