+#!/bin/sh
+# Validate NLB opaque refresh deadline calculation
+set -eu
+cd "$(dirname "$0")/.."
+CC="${CC:-cc}"
+TMP=$(mktemp -d)
+trap 'rm -rf "$TMP"' EXIT
+
+cat > "$TMP/test.c" <<'EOF'
+#include <stdio.h>
+#include <time.h>
+
+#define GP_NLB_OPAQUE_REFRESH_MARGIN 60
+
+static int ka_check_deadline(int *timeout, time_t now, time_t due)
+{
+	if (now >= due)
+		return 1;
+	if (*timeout > (due - now) * 1000)
+		*timeout = (due - now) * 1000;
+	return 0;
+}
+
+static int gpst_nlb_opaque_due(int enabled, time_t valid_until, int *timeout)
+{
+	time_t now = time(NULL);
+	time_t due;
+
+	if (!enabled || !valid_until)
+		return 0;
+
+	due = valid_until;
+	if (due > GP_NLB_OPAQUE_REFRESH_MARGIN)
+		due -= GP_NLB_OPAQUE_REFRESH_MARGIN;
+
+	return ka_check_deadline(timeout, now, due);
+}
+
+int main(void)
+{
+	int timeout = 999999;
+	time_t now = time(NULL);
+
+	if (gpst_nlb_opaque_due(0, now + 3600, &timeout))
+		return 1;
+	if (gpst_nlb_opaque_due(1, 0, &timeout))
+		return 1;
+	if (!gpst_nlb_opaque_due(1, now + 30, &timeout))
+		return 1;
+	timeout = 999999;
+	if (gpst_nlb_opaque_due(1, now + 3600, &timeout))
+		return 1;
+	printf("gp-nlb-opaque-due: OK\n");
+	return 0;
+}
+EOF
+$CC -o "$TMP/test" "$TMP/test.c"
+"$TMP/test"
\ No newline at end of file
