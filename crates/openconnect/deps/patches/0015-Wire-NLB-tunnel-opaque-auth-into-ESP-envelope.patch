-static void gp_nlb_write_hdr(unsigned char *hdr, uint16_t inner_len, uint8_t type)
+static void gp_nlb_apply_decrypted_opaque(struct openconnect_info *vpninfo,
+					  struct gp_nlb_config *nlb)
 {
+	if (!nlb->decrypted_opaque ||
+	    nlb->decrypted_opaque_len < GP_NLB_OPAQUE_AUTH_OFF + GP_NLB_HDR_AUTH_LEN)
+		return;
+
+	memcpy(nlb->hdr_auth,
+	       nlb->decrypted_opaque + GP_NLB_OPAQUE_AUTH_OFF,
+	       GP_NLB_HDR_AUTH_LEN);
+	nlb->opaque_auth_ready = 1;
+	vpn_progress(vpninfo, PRG_DEBUG,
+		     _("NLB tunnel-opaque auth material ready\n"));
+}
+
+static void gp_nlb_write_hdr(unsigned char *hdr, struct gp_nlb_config *nlb,
+			     uint16_t inner_len, uint8_t type)
+{
 	store_be32(hdr, GP_NLB_MAGIC);
-	store_be16(hdr + 4, 0);
+	store_be16(hdr + 4, nlb->wire_seq++);
 	store_be16(hdr + 6, inner_len);
 	hdr[8] = type;
 	hdr[9] = 0;
-	memset(hdr + 10, 0, 6);
+	memset(hdr + 10, 0, GP_NLB_HDR_AUTH_LEN);
 }
 
+static int gp_nlb_sign_hdr(struct openconnect_info *vpninfo,
+			   struct gp_nlb_config *nlb,
+			   unsigned char *hdr,
+			   const unsigned char *esp, int esplen)
+{
+	unsigned char mac[SHA1_SIZE];
+
+	if (nlb->hs_key_len) {
+		if (gp_nlb_hmac_sha1(nlb->hs_key, nlb->hs_key_len,
+				     hdr, GP_NLB_HDR_SIGN_LEN,
+				     esp, esplen, mac) < 0)
+			return -EINVAL;
+		memcpy(hdr + GP_NLB_HDR_SIGN_LEN, mac, GP_NLB_HDR_AUTH_LEN);
+		return 0;
+	}
+
+	if (nlb->opaque_auth_ready)
+		memcpy(hdr + GP_NLB_HDR_SIGN_LEN, nlb->hdr_auth, GP_NLB_HDR_AUTH_LEN);
+
+	return 0;
+}
+
+static int gp_nlb_verify_hdr(struct openconnect_info *vpninfo,
+			     struct gp_nlb_config *nlb,
+			     const unsigned char *hdr,
+			     const unsigned char *esp, int esplen)
+{
+	unsigned char mac[SHA1_SIZE];
+	const unsigned char *expect;
+
+	if (!nlb->hs_key_len)
+		return 0;
+
+	if (gp_nlb_hmac_sha1(nlb->hs_key, nlb->hs_key_len,
+			     hdr, GP_NLB_HDR_SIGN_LEN,
+			     esp, esplen, mac) < 0)
+		return -EINVAL;
+
+	expect = hdr + GP_NLB_HDR_SIGN_LEN;
+	if (memcmp(expect, mac, GP_NLB_HDR_AUTH_LEN)) {
+		vpn_progress(vpninfo, PRG_DEBUG,
+			     _("NLB envelope HMAC mismatch\n"));
+		return -EINVAL;
+	}
+	return 0;
+}
