From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Kevin Yue <yuezk001@gmail.com>
Date: Thu, 25 Jun 2026 23:45:00 +0800
Subject: [PATCH 15/15] Wire NLB tunnel-opaque auth into ESP envelope

Extract 6-byte auth material from decrypted tunnel-opaque offset +8,
increment wire sequence in header bytes 4-5, and sign NLB envelopes with
HMAC-SHA1 using hs-key over the 10-byte header prefix plus ESP payload.
---
diff --git a/gnutls.c b/gnutls.c
--- a/gnutls.c
+++ b/gnutls.c
@@ -3732,3 +3732,30 @@
 	return gp_aes_cbc_decrypt(use_key, key_size, use_iv, iv_size,
 				  in, inlen, out, outlen);
 }
+
+int gp_nlb_hmac_sha1(const unsigned char *key, int key_len,
+		     const unsigned char *data1, int len1,
+		     const unsigned char *data2, int len2,
+		     unsigned char *out)
+{
+	gnutls_hmac_hd_t hd;
+
+	if (!key || key_len <= 0 || !data1 || len1 < 0 || !out)
+		return -EINVAL;
+	if (len2 < 0 || (len2 > 0 && !data2))
+		return -EINVAL;
+
+	if (gnutls_hmac_init(&hd, GNUTLS_MAC_SHA1, key, key_len) < 0)
+		return -EINVAL;
+	if (gnutls_hmac(hd, data1, len1) < 0) {
+		gnutls_hmac_deinit(hd, NULL);
+		return -EINVAL;
+	}
+	if (len2 > 0 && gnutls_hmac(hd, data2, len2) < 0) {
+		gnutls_hmac_deinit(hd, NULL);
+		return -EINVAL;
+	}
+	gnutls_hmac_output(hd, out);
+	gnutls_hmac_deinit(hd, NULL);
+	return 0;
+}
