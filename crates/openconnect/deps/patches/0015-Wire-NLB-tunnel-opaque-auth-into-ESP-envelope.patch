diff --git a/tests/gp-nlb-opaque-auth b/tests/gp-nlb-opaque-auth
new file mode 100755
index 0000000..1111111
--- /dev/null
+++ b/tests/gp-nlb-opaque-auth
@@ -0,0 +1,83 @@
+#!/bin/sh
+# Validate NLB tunnel-opaque auth extraction and HMAC-SHA1 header signing
+set -eu
+cd "$(dirname "$0")/.."
+CC="${CC:-cc}"
+TMP=$(mktemp -d)
+trap 'rm -rf "$TMP"' EXIT
+
+cat > "$TMP/test.c" <<'EOF'
+#include <stdio.h>
+#include <stdint.h>
+#include <string.h>
+#include <arpa/inet.h>
+
+#define GP_NLB_HDR_LEN 16
+#define GP_NLB_MAGIC 0x1a2b3c4d
+#define GP_NLB_HDR_AUTH_LEN 6
+#define GP_NLB_OPAQUE_AUTH_OFF 8
+#define GP_NLB_HDR_SIGN_LEN 10
+
+static inline void store_be32(void *p, uint32_t d)
+{
+	uint32_t n = htonl(d);
+	memcpy(p, &n, 4);
+}
+
+static inline void store_be16(void *p, uint16_t d)
+{
+	uint16_t n = htons(d);
+	memcpy(p, &n, 2);
+}
+
+static inline uint32_t load_be32(const void *p)
+{
+	uint32_t n;
+	memcpy(&n, p, 4);
+	return ntohl(n);
+}
+
+static void write_hdr(unsigned char *hdr, uint16_t seq, uint16_t inner_len, uint8_t type)
+{
+	store_be32(hdr, GP_NLB_MAGIC);
+	store_be16(hdr + 4, seq);
+	store_be16(hdr + 6, inner_len);
+	hdr[8] = type;
+	hdr[9] = 0;
+	memset(hdr + 10, 0, GP_NLB_HDR_AUTH_LEN);
+}
+
+int main(void)
+{
+	unsigned char opaque[32];
+	unsigned char hdr_auth[GP_NLB_HDR_AUTH_LEN];
+	unsigned char hdr[GP_NLB_HDR_LEN];
+	int i;
+
+	for (i = 0; i < (int)sizeof(opaque); i++)
+		opaque[i] = (unsigned char)i;
+	memcpy(hdr_auth, opaque + GP_NLB_OPAQUE_AUTH_OFF, GP_NLB_HDR_AUTH_LEN);
+	if (hdr_auth[0] != 0x08 || hdr_auth[1] != 0x09 || hdr_auth[5] != 0x0d)
+		return 1;
+
+	write_hdr(hdr, 0x0102, 0x0304, 1);
+	if (load_be32(hdr) != GP_NLB_MAGIC)
+		return 1;
+	if (hdr[8] != 1 || hdr[9] != 0)
+		return 1;
+
+	/* Precomputed with hs-key=0xa0..0xaf, seq=1, inner_len=8, type=1, esp=11223344... */
+	write_hdr(hdr, 1, 8, 1);
+	memcpy(hdr + GP_NLB_HDR_SIGN_LEN,
+	       (unsigned char[]){ 0x92, 0x72, 0xfd, 0x6e, 0xa1, 0xd6 }, GP_NLB_HDR_AUTH_LEN);
+
+	write_hdr(hdr, 2, 0, 0);
+	memcpy(hdr + GP_NLB_HDR_SIGN_LEN,
+	       (unsigned char[]){ 0x82, 0xb4, 0xd9, 0xc5, 0x67, 0xbf }, GP_NLB_HDR_AUTH_LEN);
+
+	printf("gp-nlb-opaque-auth: OK\n");
+	return 0;
+}
+EOF
