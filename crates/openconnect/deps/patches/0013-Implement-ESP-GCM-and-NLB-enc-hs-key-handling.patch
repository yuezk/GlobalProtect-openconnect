+			return -EIO;
+		if (esp_gcm_aad(vpninfo, hd, pkt))
+			goto gcm_fail;
+
+		pkt->len -= vpninfo->hmac_out_len;
+
+		err = gnutls_cipher_decrypt(hd, pkt->data, pkt->len);
+		if (err) {
+			vpn_progress(vpninfo, PRG_DEBUG,
+				     _("Decrypting ESP GCM packet failed: %s\n"),
+				     gnutls_strerror(err));
