 	err = gnutls_hmac(esp->hmac, &pkt->esp, sizeof(pkt->esp) + pkt->len);
 	if (err) {
 		vpn_progress(vpninfo, PRG_ERR,
@@ -137,9 +241,6 @@ int decrypt_esp_packet(struct openconnect_info *vpninfo, struct esp *esp, struct
