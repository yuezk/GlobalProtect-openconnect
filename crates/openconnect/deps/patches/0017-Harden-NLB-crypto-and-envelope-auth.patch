-	memcpy(hdr + GP_NLB_HDR_SIGN_LEN,
-	       (unsigned char[]){ 0x82, 0xb4, 0xd9, 0xc5, 0x67, 0xbf }, GP_NLB_HDR_AUTH_LEN);
+	if (nlb_hmac_sha1(key, sizeof(key), hdr, GP_NLB_HDR_SIGN_LEN, NULL, 0, mac) < 0)
+		return 1;
+	if (check_tag(mac, (unsigned char[]){ 0x82, 0xb4, 0xd9, 0xc5, 0x67, 0xbf }))
+		return 1;
 
 	printf("gp-nlb-opaque-auth: OK\n");
 	return 0;
 }
