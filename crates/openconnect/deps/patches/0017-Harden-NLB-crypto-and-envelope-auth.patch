 #!/bin/sh
-# Validate NLB tunnel-opaque auth extraction and HMAC-SHA1 header signing
+# Validate NLB envelope HMAC-SHA1 signing vectors
 set -eu
 cd "$(dirname "$0")/.."
 CC="${CC:-cc}"
 TMP=$(mktemp -d)
 trap 'rm -rf "$TMP"' EXIT
 
+CFLAGS="${CFLAGS:-}"
+LIBS="${LIBS:-}"
+if pkg-config --exists openssl 2>/dev/null; then
+	CFLAGS="$CFLAGS $(pkg-config --cflags openssl)"
+	LIBS="$LIBS $(pkg-config --libs openssl)"
+elif pkg-config --exists libssl 2>/dev/null; then
+	CFLAGS="$CFLAGS $(pkg-config --cflags libssl)"
+	LIBS="$LIBS $(pkg-config --libs libssl)"
+else
+	CFLAGS="$CFLAGS -I/usr/include -I/usr/local/include -I/opt/homebrew/include"
+	LIBS="$LIBS -lcrypto -lssl"
+fi
+
 cat > "$TMP/test.c" <<'EOF'
 #include <stdio.h>
 #include <stdint.h>
 #include <string.h>
 #include <arpa/inet.h>
+#include <openssl/hmac.h>
+#include <openssl/sha.h>
 
 #define GP_NLB_HDR_LEN 16
 #define GP_NLB_MAGIC 0x1a2b3c4d
 #define GP_NLB_HDR_AUTH_LEN 6
-#define GP_NLB_OPAQUE_AUTH_OFF 8
 #define GP_NLB_HDR_SIGN_LEN 10
 
 static inline void store_be32(void *p, uint32_t d)
@@ -30,13 +44,6 @@
 	memcpy(p, &n, 2);
 }
 
-static inline uint32_t load_be32(const void *p)
-{
-	uint32_t n;
-	memcpy(&n, p, 4);
-	return ntohl(n);
-}
-
 static void write_hdr(unsigned char *hdr, uint16_t seq, uint16_t inner_len, uint8_t type)
 {
 	store_be32(hdr, GP_NLB_MAGIC);
@@ -47,37 +54,61 @@
 	memset(hdr + 10, 0, GP_NLB_HDR_AUTH_LEN);
 }
 
+static int nlb_hmac_sha1(const unsigned char *key, int key_len,
+			 const unsigned char *hdr, int hdrlen,
+			 const unsigned char *esp, int esplen,
+			 unsigned char *out)
+{
+	unsigned char mac[SHA_DIGEST_LENGTH];
+	unsigned int maclen = sizeof(mac);
+	HMAC_CTX *ctx;
+
+	ctx = HMAC_CTX_new();
+	if (!ctx)
+		return -1;
+	if (!HMAC_Init_ex(ctx, key, key_len, EVP_sha1(), NULL) ||
+	    !HMAC_Update(ctx, hdr, hdrlen) ||
+	    (esplen > 0 && !HMAC_Update(ctx, esp, esplen)) ||
+	    !HMAC_Final(ctx, mac, &maclen)) {
+		HMAC_CTX_free(ctx);
+		return -1;
+	}
+	HMAC_CTX_free(ctx);
+	memcpy(out, mac, GP_NLB_HDR_AUTH_LEN);
+	return 0;
+}
+
+static int check_tag(const unsigned char *got, const unsigned char *expect)
+{
+	return memcmp(got, expect, GP_NLB_HDR_AUTH_LEN) == 0 ? 0 : 1;
+}
+
 int main(void)
 {
-	unsigned char opaque[32];
