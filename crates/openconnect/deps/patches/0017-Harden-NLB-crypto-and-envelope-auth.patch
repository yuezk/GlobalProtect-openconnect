+	for (i = 0; i < (int)sizeof(key); i++)
+		key[i] = (unsigned char)(0xa0 + i);
 
-	write_hdr(hdr, 0x0102, 0x0304, 1);
-	if (load_be32(hdr) != GP_NLB_MAGIC)
+	write_hdr(hdr, 1, 8, 1);
+	if (nlb_hmac_sha1(key, sizeof(key), hdr, GP_NLB_HDR_SIGN_LEN, esp, sizeof(esp), mac) < 0)
 		return 1;
-	if (hdr[8] != 1 || hdr[9] != 0)
+	if (check_tag(mac, (unsigned char[]){ 0x92, 0x72, 0xfd, 0x6e, 0xa1, 0xd6 }))
 		return 1;
 
