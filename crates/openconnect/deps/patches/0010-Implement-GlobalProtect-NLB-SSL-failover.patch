--- a/tests/gp-nlb-ssl-connect	2026-06-25 18:36:12
+++ b/tests/gp-nlb-ssl-connect	2026-06-25 18:36:07
@@ -0,0 +1,109 @@
+#!/bin/sh
+# Validate NLB SSL tunnel response detection (issue #526 format)
+set -eu
+cd "$(dirname "$0")/.."
+CC="${CC:-cc}"
+TMP=$(mktemp -d)
+trap 'rm -rf "$TMP"' EXIT
+
+cat > "$TMP/test.c" <<'EOF'
+#include <stdio.h>
+#include <string.h>
+#include <arpa/inet.h>
+#include <ctype.h>
+#include <stdlib.h>
+
+struct gp_nlb_config {
+	char *tunnel_vip;
+	char *inner_gw_ip;
+	char *in_tunnel_gw_cert_chksum;
+	int enabled;
+};
+
+#define GP_NLB_SSL_PROTO_VERSION 110
+
+static int gp_nlb_is_ipv4(const char *s)
+{
+	struct in_addr a;
+	return s && inet_pton(AF_INET, s, &a) == 1;
+}
+
+static int gp_nlb_split_concat_ips(const char *concat, const char *hint_vip,
+				     char **vip, char **inner)
+{
+	size_t vip_len;
+
+	if (!concat || !*concat)
+		return -1;
+
+	if (hint_vip && !strncmp(concat, hint_vip, strlen(hint_vip))) {
+		vip_len = strlen(hint_vip);
+		if (concat[vip_len] && gp_nlb_is_ipv4(concat + vip_len)) {
+			*vip = strdup(hint_vip);
+			*inner = strdup(concat + vip_len);
+			return 0;
+		}
+	}
+	return -1;
+}
+
+static int gpst_nlb_parse_ssl_response(const char *buf, int len, struct gp_nlb_config *nlb)
+{
+	char *line, *vip = NULL, *inner = NULL, *hash, *start, *concat;
+	const char *hint_vip;
+	long version;
+
+	line = strndup(buf, len);
+	start = strstr(line, " START_TUNNEL");
+	if (!start)
+		return -1;
+	*start = '\0';
+	hash = strrchr(line, ' ');
+	if (!hash)
+		return -1;
+	*hash++ = '\0';
+	if (sscanf(line, "%ld", &version) != 1 || version != GP_NLB_SSL_PROTO_VERSION)
+		return -1;
+	concat = strchr(line, ' ') + 1;
+	hint_vip = "127.127.127.127";
+	if (gp_nlb_split_concat_ips(concat, hint_vip, &vip, &inner))
+		return -1;
+	nlb->tunnel_vip = vip;
+	nlb->inner_gw_ip = inner;
+	nlb->in_tunnel_gw_cert_chksum = strdup(hash);
+	nlb->enabled = 1;
+	return 0;
+}
+
+static int gpst_nlb_handle_ssl_connect_response(const char *buf, int len, struct gp_nlb_config *nlb)
+{
+	static const char start_tunnel[] = "START_TUNNEL";
+
+	if (!buf || len <= 0)
+		return -1;
+	if (len >= 12 && !strncmp(buf, start_tunnel, 12))
+		return 0;
+	if (!strstr(buf, start_tunnel))
+		return -1;
+	return gpst_nlb_parse_ssl_response(buf, len, nlb);
+}
+
+int main(void)
+{
+	struct gp_nlb_config nlb = {0};
+	const char *sample = "110 127.127.127.127192.168.255.43 c057fc7f7c6b74f9ac68b639bb056732404cbacf START_TUNNEL";
+	const char *plain = "START_TUNNEL";
+
+	if (gpst_nlb_handle_ssl_connect_response(plain, strlen(plain), &nlb))
+		return 1;
+	if (gpst_nlb_handle_ssl_connect_response(sample, strlen(sample), &nlb))
+		return 1;
+	if (strcmp(nlb.tunnel_vip, "127.127.127.127") ||
+	    strcmp(nlb.inner_gw_ip, "192.168.255.43"))
+		return 1;
+	printf("gp-nlb-ssl-connect: OK\n");
+	return 0;
+}
+EOF
+$CC -o "$TMP/test" "$TMP/test.c"
+"$TMP/test"
